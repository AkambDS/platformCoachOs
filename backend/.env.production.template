# ── CoachOS Production Environment ────────────────────────────────────────────
# Copy to backend/.env and fill in all values before deployment

# ── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_use_python_secrets_token_urlsafe_50
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DOMAIN=yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://coachos:CHANGEME_DB_PASSWORD@db:5432/coachos
DB_PASSWORD=CHANGEME_DB_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_LIVE_SECRET_KEY=sk_live_...
STRIPE_TEST_SECRET_KEY=sk_test_...
DJSTRIPE_WEBHOOK_SECRET=whsec_...
# Set to True in production
STRIPE_LIVE_MODE=True

# ── AWS S3 (file storage) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_STORAGE_BUCKET_NAME=coachos-files
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=

# ── Email ─────────────────────────────────────────────────────────────────────
# Option A: SendGrid
SENDGRID_API_KEY=SG...
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
# Option B: SMTP
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_HOST_USER=...
# EMAIL_HOST_PASSWORD=...
# EMAIL_USE_TLS=True

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Google OAuth & Calendar ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://yourdomain.com/accounts/google/login/callback/

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SITE_ID=1
